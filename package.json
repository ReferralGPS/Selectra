{
  "name": "@referralgps/selectra",
  "keywords": [
    "selectize",
    "tokenize",
    "select2",
    "selectize.js with Alpinejs + TailwindCSS"
  ],
  "type": "module",
  "main": "dist/selectra.umd.js",
  "module": "dist/selectra.es.js",
  "browser": "dist/selectra.umd.js",
  "exports": {
    ".": {
      "import": "./dist/selectra.es.js",
      "require": "./dist/selectra.umd.js"
    },
    "./css": "./dist/selectra.css"
  },
  "description": "Selectra — A powerful, extensible <select> UI control for tagging, contact lists, country selectors, and autocomplete. Built with Alpine.js and Tailwind CSS.",
  "version": "1.0.6",
  "author": "Brijesh Sajeev<mailtobrijesh2003@gmail.com>",
  "contributors": [
    "Gajendra Jena <gaju.mca@gmail.com>"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ReferralGPS/Selectra.git"
  },
  "files": [
    "dist/*",
    "src-alpine/*"
  ],
  "devDependencies": {
    "tailwindcss": "^3.0.0",
    "autoprefixer": "^10.4.20",
    "terser": "^5.36.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "alpinejs": "^3.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
