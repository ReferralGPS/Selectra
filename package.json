{
  "name": "@referralgps/selectra",
  "keywords": [
    "select",
    "ui",
    "form",
    "input",
    "control",
    "autocomplete",
    "tagging",
    "tag",
    "alpine",
    "alpinejs",
    "tailwindcss"
  ],
  "type": "module",
  "main": "dist/selectra.umd.js",
  "module": "dist/selectra.es.js",
  "browser": "dist/selectra.umd.js",
  "exports": {
    ".": {
      "import": "./dist/selectra.es.js",
      "require": "./dist/selectra.umd.js"
    },
    "./css": "./dist/selectra.css"
  },
  "description": "Selectra — A powerful, extensible <select> UI control for tagging, contact lists, country selectors, and autocomplete. Built with Alpine.js and Tailwind CSS.",
  "version": "1.0.0",
  "author": "Brian Reavis <brian@thirdroute.com>",
  "contributors": [
    "Ris Adams <selectize@risadams.com>"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ReferralGPS/Selectra.git"
  },
  "files": [
    "dist/*",
    "src-alpine/*"
  ],
  "devDependencies": {
    "alpinejs": "^3.14.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "terser": "^5.36.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "alpinejs": "^3.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
